import os
import shlex
import shutil
import sys
import traceback

from module_utils import module_strip_ssml


def parse_config(path):
    config = {
        "python": "python3",
        "language": "english",
        "voice": "",
        "voices": [],
    }
    if path is None:
        return config

    with open(path, encoding="utf-8") as handle:
        for raw_line in handle:
            parts = shlex.split(raw_line, comments=True)
            if not parts:
                continue

            key, values = parts[0], parts[1:]
            if key == "PocketTTSPython" and values:
                config["python"] = values[0]
            elif key == "PocketTTSLanguage" and values:
                config["language"] = values[0]
            elif key == "PocketTTSDefaultVoice" and values:
                config["voice"] = values[0]
            elif key == "AddVoice" and len(values) >= 3:
                config["voices"].append(tuple(values[:3]))
                if not config["voice"]:
                    config["voice"] = values[2]
            elif key != "Debug":
                raise ValueError(f"unknown directive {key!r}")

    return config


def maybe_reexec(config, argv):
    if "--no-reexec" in argv or not config["python"]:
        return

    target = config["python"]
    resolved = shutil.which(target) if os.path.sep not in target else target
    if resolved and os.path.abspath(resolved) == os.path.abspath(sys.executable):
        return

    os.execvp(target, [target, __file__, *argv[1:], "--no-reexec"])


class PocketTTSModule:
    def __init__(self, config):
        self.config = config
        self.model = None
        self.default_voice = config["voice"]
        self.voice = config["voice"]
        self.voice_state = None
        self.voice_state_name = None
        self.volume = 0

    def initialize(self):
        from pocket_tts import TTSModel
        from pocket_tts.default_parameters import get_default_voice_for_language

        self.model = TTSModel.load_model(language=self.config["language"])
        if not self.default_voice:
            self.default_voice = get_default_voice_for_language(self.config["language"])
        self.voice = self.voice or self.default_voice
        self.state_for_current_voice()

    def state_for_current_voice(self):
        if self.voice_state is None or self.voice_state_name != self.voice:
            self.voice_state = self.model.get_state_for_audio_prompt(self.voice)
            self.voice_state_name = self.voice
        return self.voice_state

    def set_parameter(self, var, val):
        if var == "volume":
            try:
                self.volume = max(-100, min(100, int(val)))
            except ValueError:
                return False
        elif var == "synthesis_voice":
            self.voice = self.default_voice if val == "NULL" else val
            self.voice_state = None
        elif var == "language":
            self.select_configured_voice(language=val)
        elif var == "voice":
            self.select_configured_voice(voice_type=val)
        return True

    def select_configured_voice(self, language=None, voice_type=None):
        for candidate_language, candidate_type, candidate_voice in self.config["voices"]:
            same_language = language is None or languages_match(language, candidate_language)
            same_type = voice_type is None or voice_type.upper() == candidate_type.upper()
            if same_language and same_type:
                if self.voice != candidate_voice:
                    self.voice = candidate_voice
                    self.voice_state = None
                return

    def speak(self, text, message_type):
        if message_type == "TEXT":
            text = module_strip_ssml(text)
        elif text == "space" or text.isspace():
            text = "space"

        if not text.strip():
            reply("301 ERROR CANT SPEAK")
            return

        try:
            stream = self.model.generate_audio_stream(self.state_for_current_voice(), text)
        except Exception:
            traceback.print_exc(file=sys.stderr)
            reply("301 ERROR CANT SPEAK")
            return

        reply("200 OK SPEAKING")
        reply("701 BEGIN")
        try:
            for chunk in stream:
                write_audio_chunk(chunk, self.model.sample_rate, self.volume)
        except Exception:
            traceback.print_exc(file=sys.stderr)
            reply("703 STOP")
            return
        reply("702 END")

    def list_voices(self):
        if not self.config["voices"]:
            reply("304 CANT LIST VOICES")
            return

        for language, voice_type, voice in self.config["voices"]:
            print(f"200-{voice}\t{language}\t{voice_type}", flush=False)
        reply("200 OK VOICE LIST SENT")


def languages_match(requested, candidate):
    requested = requested.lower().replace("_", "-")
    candidate = candidate.lower().replace("_", "-")
    return requested == candidate or requested.split("-", 1)[0] == candidate.split("-", 1)[0]


def read_message():
    lines = []
    while True:
        line = sys.stdin.readline()
        if line == "":
            raise EOFError
        if line == ".\n":
            break
        if line.startswith(".."):
            line = line[1:]
        lines.append(line)

    text = "".join(lines)
    return text[:-1] if text.endswith("\n") else text, len(lines)


def receive_settings(status, label, setter):
    reply(f"{status} OK RECEIVING {label}SETTINGS")
    ok = True
    while True:
        line = sys.stdin.readline()
        if line == "":
            raise EOFError
        if line == ".\n":
            break
        if "=" not in line:
            ok = False
            continue
        var, val = line.rstrip("\n").split("=", 1)
        ok = setter(var, val) and ok
    return ok


def volume_gain(volume):
    return (volume + 100) / 100.0 if volume < 0 else 1.0 + volume / 100.0


def write_audio_chunk(chunk, sample_rate, volume):
    torch = __import__("torch")
    audio = chunk.detach().cpu().reshape(-1) * volume_gain(volume)
    pcm = (
        (audio.clamp(-1, 1) * 32767)
        .to(torch.int16)
        .contiguous()
        .cpu()
        .numpy()
        .tobytes()
    )

    for offset in range(0, len(pcm), 10000):
        chunk = pcm[offset : offset + 10000]
        payload = escape_audio(chunk)
        print("705-bits=16")
        print("705-num_channels=1")
        print(f"705-sample_rate={sample_rate}")
        print(f"705-num_samples={len(chunk) // 2}")
        print("705-big_endian=0")
        print("705-AUDIO", end="", flush=True)
        sys.stdout.buffer.write(b"\0" + payload + b"\n705 AUDIO\n")
        sys.stdout.buffer.flush()


def escape_audio(payload):
    escaped = bytearray()
    for byte in payload:
        if byte in (0x0A, 0x7D):
            escaped.append(0x7D)
            escaped.append(byte ^ 0x20)
        else:
            escaped.append(byte)
    return bytes(escaped)


def reply(line):
    print(line, flush=True)


def init_error(error):
    for line in str(error).splitlines():
        print(f"399-{line}", flush=False)
    reply("399 ERR CANT INIT MODULE")


def config_path(argv):
    for arg in argv[1:]:
        if not arg.startswith("--"):
            return arg
    return None


def main():
    try:
        config = parse_config(config_path(sys.argv))
        maybe_reexec(config, sys.argv)
    except Exception as error:
        config = None
        config_error = error
    else:
        config_error = None

    if sys.stdin.readline() != "INIT\n":
        init_error("Server did not start with INIT")
        return 1

    if config_error is not None:
        init_error(config_error)
        return 1

    module = PocketTTSModule(config)
    try:
        module.initialize()
    except Exception:
        init_error(traceback.format_exc())
        return 1

    reply("299-Pocket TTS initialized successfully.")
    reply("299 OK LOADED SUCCESSFULLY")

    try:
        while True:
            command = sys.stdin.readline()
            if command == "":
                return 1
            command = command.rstrip("\n")

            if command in {"SPEAK", "CHAR", "KEY", "SOUND_ICON"}:
                reply("202 OK RECEIVING MESSAGE")
                text, lines = read_message()
                if command in {"CHAR", "KEY", "SOUND_ICON"} and lines > 1:
                    reply("305 DATA MORE THAN ONE LINE")
                elif command == "SOUND_ICON":
                    reply("301 ERROR CANT SPEAK")
                else:
                    module.speak(text, "TEXT" if command == "SPEAK" else command)
            elif command in {"STOP", "PAUSE"}:
                continue
            elif command.startswith("LIST VOICES"):
                module.list_voices()
            elif command == "SET":
                if receive_settings(203, "", module.set_parameter):
                    reply("203 OK SETTINGS RECEIVED")
                else:
                    reply("303 ERROR INVALID PARAMETER OR VALUE")
            elif command == "AUDIO":
                receive_settings(207, "AUDIO ", lambda _var, _val: True)
                reply("203 OK AUDIO INITIALIZED")
            elif command == "LOGLEVEL":
                receive_settings(207, "LOGLEVEL ", lambda _var, _val: True)
                reply("203 OK LOGLEVEL SET")
            elif command.startswith("DEBUG"):
                reply("200 OK DEBUGGING ON" if " ON" in command else "200 OK DEBUGGING OFF")
            elif command == "QUIT":
                reply("210 OK QUIT")
                return 0
            else:
                reply("300 ERR UNKNOWN COMMAND")
    except EOFError:
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
