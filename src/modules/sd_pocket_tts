import os
import shlex
import shutil
import sys
import traceback

from module_main import run_main
from module_process import (
    MESSAGE_TEXT,
    event_begin,
    event_end,
    event_stop,
    languages_match,
    speak_error,
    speak_ok,
    write_audio_pcm,
)
from module_utils import module_strip_ssml


def parse_config(path):
    config = {
        "python": "python3",
        "language": "english",
        "voice": "",
        "voices": [],
    }
    if path is None:
        return config

    with open(path, encoding="utf-8") as handle:
        for raw_line in handle:
            parts = shlex.split(raw_line, comments=True)
            if not parts:
                continue

            key, values = parts[0], parts[1:]
            if key == "PocketTTSPython" and values:
                config["python"] = values[0]
            elif key == "PocketTTSLanguage" and values:
                config["language"] = values[0]
            elif key == "PocketTTSDefaultVoice" and values:
                config["voice"] = values[0]
            elif key == "AddVoice" and len(values) >= 3:
                config["voices"].append(tuple(values[:3]))
                if not config["voice"]:
                    config["voice"] = values[2]
            elif key != "Debug":
                raise ValueError(f"unknown directive {key!r}")

    return config


def maybe_reexec(config, argv):
    if "--no-reexec" in argv or not config["python"]:
        return

    target = config["python"]
    resolved = shutil.which(target) if os.path.sep not in target else target
    if resolved and os.path.abspath(resolved) == os.path.abspath(sys.executable):
        return

    os.execvp(target, [target, __file__, *argv[1:], "--no-reexec"])


class PocketTTSModule:
    def __init__(self, config):
        self.config = config
        self.model = None
        self.default_voice = config["voice"]
        self.voice = config["voice"]
        self.voice_state = None
        self.voice_state_name = None
        self.volume = 0

    def initialize(self):
        from pocket_tts import TTSModel
        from pocket_tts.default_parameters import get_default_voice_for_language

        self.model = TTSModel.load_model(language=self.config["language"])
        if not self.default_voice:
            self.default_voice = get_default_voice_for_language(self.config["language"])
        self.voice = self.voice or self.default_voice
        self.state_for_current_voice()

    def state_for_current_voice(self):
        if self.voice_state is None or self.voice_state_name != self.voice:
            self.voice_state = self.model.get_state_for_audio_prompt(self.voice)
            self.voice_state_name = self.voice
        return self.voice_state

    def set_parameter(self, var, val):
        if var == "volume":
            try:
                self.volume = max(-100, min(100, int(val)))
            except ValueError:
                return False
        elif var == "synthesis_voice":
            self.voice = self.default_voice if val == "NULL" else val
            self.voice_state = None
        elif var == "language":
            self.select_configured_voice(language=val)
        elif var == "voice":
            self.select_configured_voice(voice_type=val)
        return True

    def select_configured_voice(self, language=None, voice_type=None):
        for candidate_language, candidate_type, candidate_voice in self.config["voices"]:
            same_language = language is None or languages_match(language, candidate_language)
            same_type = voice_type is None or voice_type.upper() == candidate_type.upper()
            if same_language and same_type:
                if self.voice != candidate_voice:
                    self.voice = candidate_voice
                    self.voice_state = None
                return

    def speak(self, text, message_type):
        if message_type == MESSAGE_TEXT:
            text = module_strip_ssml(text)
        elif text == "space" or text.isspace():
            text = "space"

        if not text.strip():
            speak_error()
            return

        try:
            stream = self.model.generate_audio_stream(self.state_for_current_voice(), text)
        except Exception:
            traceback.print_exc(file=sys.stderr)
            speak_error()
            return

        speak_ok()
        event_begin()
        try:
            for chunk in stream:
                write_audio_chunk(chunk, self.model.sample_rate, self.volume)
        except Exception:
            traceback.print_exc(file=sys.stderr)
            event_stop()
            return
        event_end()

    def list_voices(self):
        return self.config["voices"]


def volume_gain(volume):
    return (volume + 100) / 100.0 if volume < 0 else 1.0 + volume / 100.0


def write_audio_chunk(chunk, sample_rate, volume):
    torch = __import__("torch")
    audio = chunk.detach().cpu().reshape(-1) * volume_gain(volume)
    pcm = (
        (audio.clamp(-1, 1) * 32767)
        .to(torch.int16)
        .contiguous()
        .cpu()
        .numpy()
        .tobytes()
    )

    write_audio_pcm(pcm, sample_rate)


def main():
    return run_main(
        parse_config,
        PocketTTSModule,
        reexec=maybe_reexec,
        success_message="Pocket TTS initialized successfully.",
        hard_exit=True,
    )


if __name__ == "__main__":
    raise SystemExit(main())
