import io
import sys

from speechd_python_modules import module_main, speechd_types
from speechd_python_modules.module_process import module_speak_ok


class RecordingModule:
    def __init__(self):
        self.closed = False
        self.spoken = []

    def module_init(self):
        return "fake initialized"

    def module_speak_sync(self, text, text_len, msgtype):
        self.spoken.append((text, text_len, msgtype))
        module_speak_ok()

    def module_close(self):
        self.closed = True


text = "caf\u00e9"
expected_len = len(text.encode("utf-8"))
if len(text) == expected_len:
    raise SystemExit("test text must have different character and byte lengths")

module = RecordingModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
stdout = io.StringIO()
try:
    sys.stdin = io.StringIO("INIT\nSPEAK\n" + text + "\n.\nQUIT\n")
    sys.stdout = stdout
    ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout

if ret != 0:
    raise SystemExit("unexpected return value: %r" % ret)
if not module.closed:
    raise SystemExit("module_close was not called")
expected_spoken = [(text, expected_len, speechd_types.SPD_MSGTYPE_TEXT)]
if module.spoken != expected_spoken:
    raise SystemExit("unexpected spoken messages: %r" % (module.spoken,))
if "200 OK SPEAKING\n" not in stdout.getvalue():
    raise SystemExit("missing speak confirmation: %r" % stdout.getvalue())
PY
