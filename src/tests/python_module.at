"$PYTHON" - <<'PY'
import io
import sys

from speechd_python_modules import module_main


class InitModule:
    def __init__(self, message):
        self.closed = False
        self.message = message

    def module_init(self):
        return self.message

    def module_close(self):
        self.closed = True


def run_case(message):
    module = InitModule(message)
    old_stdin = sys.stdin
    old_stdout = sys.stdout
    stdout = io.StringIO()
    try:
        sys.stdin = io.StringIO("INIT\nQUIT\n")
        sys.stdout = stdout
        ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
    finally:
        sys.stdin = old_stdin
        sys.stdout = old_stdout

    if ret != 0:
        raise SystemExit("unexpected return value: %r" % ret)
    if not module.closed:
        raise SystemExit("module_close was not called")
    return stdout.getvalue()


expected_default = (
    "299-Unspecified initialization success\n"
    "299 OK LOADED SUCCESSFULLY\n"
    "210 OK QUIT\n"
)
default_output = run_case(None)
if default_output != expected_default:
    raise SystemExit("unexpected default init output: %r" % default_output)

expected_multiline = (
    "299-first line second line\n"
    "299 OK LOADED SUCCESSFULLY\n"
    "210 OK QUIT\n"
)
multiline_output = run_case("first line\nsecond line")
if multiline_output != expected_multiline:
    raise SystemExit("unexpected multiline init output: %r" % multiline_output)
PY
