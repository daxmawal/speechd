import io
import sys

from speechd_python_modules import module_main


class FailingModule:
    def __init__(self):
        self.closed = False

    def module_init(self):
        raise RuntimeError("first line\nsecond line")

    def module_close(self):
        self.closed = True


module = FailingModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
old_stderr = sys.stderr
stdout = io.StringIO()
stderr = io.StringIO()
try:
    sys.stdin = io.StringIO("INIT\n")
    sys.stdout = stdout
    sys.stderr = stderr
    ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout
    sys.stderr = old_stderr

expected_stdout = "399-first line second line\n399 ERR CANT INIT MODULE\n"
if ret != 1:
    raise SystemExit("unexpected return value: %r" % ret)
if not module.closed:
    raise SystemExit("module_close was not called")
if stdout.getvalue() != expected_stdout:
    raise SystemExit("unexpected stdout: %r" % stdout.getvalue())
if "Traceback" in stdout.getvalue():
    raise SystemExit("stdout contains a traceback")
if "Traceback" not in stderr.getvalue():
    raise SystemExit("stderr does not contain a traceback")
if "RuntimeError: first line" not in stderr.getvalue():
    raise SystemExit("stderr does not contain the exception")
PY
