import io
import sys

from speechd_python_modules import module_main


def fail_config(_path):
    raise RuntimeError("bad config")


old_stdout = sys.stdout
old_stderr = sys.stderr
stdout = io.StringIO()
stderr = io.StringIO()
try:
    sys.stdout = stdout
    sys.stderr = stderr
    ret = module_main.run_main(fail_config, lambda _config: object(), ["fake-module"])
finally:
    sys.stdout = old_stdout
    sys.stderr = old_stderr

if ret != 1:
    raise SystemExit("unexpected return value: %r" % ret)
if stdout.getvalue() != "":
    raise SystemExit("stdout should stay empty before INIT: %r" % stdout.getvalue())
if "Traceback" not in stderr.getvalue():
    raise SystemExit("stderr does not contain a traceback")
if "RuntimeError: bad config" not in stderr.getvalue():
    raise SystemExit("stderr does not contain the exception")
PY
