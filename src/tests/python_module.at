import io
import sys

from speechd_python_modules.module_process import cmd_audio


class LocalAudioModule:
    def __init__(self):
        self.initialized = False
        self.settings = []

    def module_audio_set(self, var, val):
        self.settings.append((var, val))
        if var == "audio_output_method" and val == "pulse":
            return 0
        if var == "audio_pulse_device":
            return 0
        return -1

    def module_audio_init(self):
        self.initialized = True
        return 0


module = LocalAudioModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
stdout = io.StringIO()
try:
    sys.stdin = io.StringIO(
        "audio_output_method=pulse\n"
        "audio_pulse_device=default\n"
        ".\n"
    )
    sys.stdout = stdout
    cmd_audio(module)
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout

expected = (
    "207 OK RECEIVING AUDIO SETTINGS\n"
    "203 OK AUDIO INITIALIZED\n"
)
if stdout.getvalue() != expected:
    raise SystemExit("unexpected AUDIO response: %r" % stdout.getvalue())
if module.settings != [
    ("audio_output_method", "pulse"),
    ("audio_pulse_device", "default"),
]:
    raise SystemExit("unexpected audio settings: %r" % module.settings)
if not module.initialized:
    raise SystemExit("module_audio_init was not called")
PY
