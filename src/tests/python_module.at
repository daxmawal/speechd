AT_SKIP_IF([test "x$TEST_PYTHON_ENABLED" != xyes])

AT_CHECK([[test_pythonpath=${TEST_PYTHONPATH-"$abs_top_srcdir/src/modules"}
PYTHONDONTWRITEBYTECODE=1 \
PYTHONNOUSERSITE=1 \
PYTHONPATH="$test_pythonpath" \
"$PYTHON" - <<'PY'
import io
import os
import sys

from speechd_python_modules import speechd_types
from speechd_python_modules.module_readline import module_readline
from speechd_python_modules.module_process import module_process, module_speak_ok


class RecordingModule:
    def __init__(self):
        self.closed = False
        self.spoken = []

    def module_speak_sync(self, text, text_len, msgtype):
        self.spoken.append((text, text_len, msgtype))
        module_speak_ok()

    def module_close(self):
        self.closed = True


module = RecordingModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
stdout = io.StringIO()
empty_read_fd = None
empty_write_fd = None
partial_read_fd = None
partial_write_fd = None
eof_partial_read_fd = None
eof_partial_write_fd = None
script_read_fd = None
script_write_fd = None
try:
    sys.stdin = io.StringIO("QUIT\n")
    sys.stdout = stdout

    empty_read_fd, empty_write_fd = os.pipe()
    ret = module_process(module, fd=empty_read_fd, block=False)
    if ret != -1:
        raise SystemExit("unexpected nonblocking return value: %r" % ret)
    if module.closed:
        raise SystemExit("module_process read from sys.stdin instead of fd")
    if stdout.getvalue() != "":
        raise SystemExit("unexpected nonblocking output: %r" % stdout.getvalue())
    os.close(empty_read_fd)
    empty_read_fd = None
    os.close(empty_write_fd)
    empty_write_fd = None

    partial_read_fd, partial_write_fd = os.pipe()
    os.write(partial_write_fd, b"partial")
    line = module_readline(partial_read_fd, block=False)
    if line is not None:
        raise SystemExit("unexpected partial nonblocking line: %r" % line)
    os.write(partial_write_fd, b"\nnext\n")
    line = module_readline(partial_read_fd, block=False)
    if line != "partial\n":
        raise SystemExit("unexpected completed line: %r" % line)
    line = module_readline(partial_read_fd, block=False)
    if line != "next\n":
        raise SystemExit("unexpected buffered line: %r" % line)
    os.close(partial_read_fd)
    partial_read_fd = None
    os.close(partial_write_fd)
    partial_write_fd = None

    eof_partial_read_fd, eof_partial_write_fd = os.pipe()
    os.write(eof_partial_write_fd, b"partial")
    os.close(eof_partial_write_fd)
    eof_partial_write_fd = None
    line = module_readline(eof_partial_read_fd, block=True)
    if line is not None:
        raise SystemExit("unexpected partial EOF line: %r" % line)
    os.close(eof_partial_read_fd)
    eof_partial_read_fd = None

    script_read_fd, script_write_fd = os.pipe()
    os.write(script_write_fd, "SPEAK\ncaf\u00e9\n.\nQUIT\n".encode("utf-8"))
    os.close(script_write_fd)
    script_write_fd = None

    ret = module_process(module, fd=script_read_fd, block=True)
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout
    for descriptor in (
        empty_read_fd,
        empty_write_fd,
        partial_read_fd,
        partial_write_fd,
        eof_partial_read_fd,
        eof_partial_write_fd,
        script_read_fd,
        script_write_fd,
    ):
        if descriptor is not None:
            os.close(descriptor)

if ret != 0:
    raise SystemExit("unexpected return value: %r" % ret)
if not module.closed:
    raise SystemExit("module_close was not called")
expected_spoken = [("caf\u00e9", 5, speechd_types.SPD_MSGTYPE_TEXT)]
if module.spoken != expected_spoken:
    raise SystemExit("unexpected spoken messages: %r" % (module.spoken,))
expected_output = (
    "202 OK RECEIVING MESSAGE\n"
    "200 OK SPEAKING\n"
    "210 OK QUIT\n"
)
if stdout.getvalue() != expected_output:
    raise SystemExit("unexpected output: %r" % stdout.getvalue())
PY
