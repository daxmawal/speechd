import io
import sys

from speechd_python_modules import module_main


class FailingCallbackModule:
    def __init__(self):
        self.closed = False
        self.settings = []

    def module_init(self):
        return "fake initialized"

    def module_list_voices(self):
        raise RuntimeError("list voices failed")

    def module_set(self, var, val):
        self.settings.append((var, val))
        raise RuntimeError("set failed")

    def module_close(self):
        self.closed = True
        raise RuntimeError("close failed")


module = FailingCallbackModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
old_stderr = sys.stderr
stdout = io.StringIO()
stderr = io.StringIO()
try:
    sys.stdin = io.StringIO(
        "INIT\n"
        "LIST VOICES\n"
        "SET\n"
        "voice=fake\n"
        ".\n"
        "QUIT\n"
    )
    sys.stdout = stdout
    sys.stderr = stderr
    ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout
    sys.stderr = old_stderr

expected = (
    "299-fake initialized\n"
    "299 OK LOADED SUCCESSFULLY\n"
    "304 CANT LIST VOICES\n"
    "203 OK RECEIVING SETTINGS\n"
    "303 ERROR INVALID PARAMETER OR VALUE\n"
    "210 OK QUIT\n"
)
if stdout.getvalue() != expected:
    raise SystemExit("unexpected protocol output: %r" % stdout.getvalue())
if "Traceback" in stdout.getvalue():
    raise SystemExit("stdout contains a traceback")
if "399 ERR MODULE CLOSED" in stdout.getvalue():
    raise SystemExit("module loop did not recover after backend errors")
if ret != 0:
    raise SystemExit("unexpected return value: %r" % ret)
if not module.closed:
    raise SystemExit("module_close was not called")
if module.settings != [("voice", "fake")]:
    raise SystemExit("unexpected SET values: %r" % module.settings)
error_output = stderr.getvalue()
for needle in (
    "RuntimeError: list voices failed",
    "RuntimeError: set failed",
    "RuntimeError: close failed",
):
    if needle not in error_output:
        raise SystemExit("stderr does not contain %r in %r" % (needle, error_output))
