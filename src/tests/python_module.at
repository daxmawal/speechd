import io
import sys

from speechd_python_modules import module_main, speechd_types


class FailingSpeakModule:
    def __init__(self):
        self.closed = False
        self.spoken = []

    def module_init(self):
        return "fake initialized"

    def module_speak_sync(self, text, text_len, msgtype):
        self.spoken.append((text, text_len, msgtype))
        raise RuntimeError("speak failed")

    def module_close(self):
        self.closed = True


module = FailingSpeakModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
old_stderr = sys.stderr
stdout = io.StringIO()
stderr = io.StringIO()
try:
    sys.stdin = io.StringIO("INIT\nSPEAK\nHello\n.\nQUIT\n")
    sys.stdout = stdout
    sys.stderr = stderr
    ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
finally:
    sys.stdin = old_stdin
    sys.stdout = old_stdout
    sys.stderr = old_stderr

output = stdout.getvalue()
required = [
    "299-fake initialized\n",
    "299 OK LOADED SUCCESSFULLY\n",
    "202 OK RECEIVING MESSAGE\n",
    "301 ERROR CANT SPEAK\n",
    "210 OK QUIT\n",
]
for needle in required:
    if needle not in output:
        raise SystemExit("missing stdout %r in %r" % (needle, output))
if "Traceback" in output:
    raise SystemExit("stdout contains a traceback")
if "399 ERR MODULE CLOSED" in output:
    raise SystemExit("module loop did not recover after speak error")
if ret != 0:
    raise SystemExit("unexpected return value: %r" % ret)
if not module.closed:
    raise SystemExit("module_close was not called")
if module.spoken != [("Hello", 5, speechd_types.SPD_MSGTYPE_TEXT)]:
    raise SystemExit("unexpected spoken messages: %r" % (module.spoken,))
if "Traceback" not in stderr.getvalue():
    raise SystemExit("stderr does not contain a traceback")
if "RuntimeError: speak failed" not in stderr.getvalue():
    raise SystemExit("stderr does not contain the exception")
PY
