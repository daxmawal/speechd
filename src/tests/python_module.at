import io
import sys

from speechd_python_modules import module_main, speechd_types
from speechd_python_modules.module_process import module_speak_ok


class EdgeModule:
    def __init__(self):
        self.closed = False
        self.spoken = []

    def module_init(self):
        return "edge initialized"

    def module_list_voices(self):
        return [speechd_types.SPDVoice("fake-en", "en-US", "MALE1")]

    def module_speak_sync(self, text, text_len, msgtype):
        self.spoken.append((text, text_len, msgtype))
        module_speak_ok()

    def module_close(self):
        self.closed = True


script = (
    "INIT\n"
    "SPEAK\n"
    ".\n"
    "CHAR\n"
    "a\n"
    "b\n"
    ".\n"
    "SPEAK\n"
    ".First\n"
    ".\n"
    "LIST VOICES de\n"
    "QUIT\n"
)

module = EdgeModule()
old_stdin = sys.stdin
old_stdout = sys.stdout
stdout = io.StringIO()
try:
    sys.stdin = io.StringIO(script)
    sys.stdout = stdout
    ret = module_main.run_main(lambda _path: {}, lambda _config: module, ["fake-module"])
finally:
