AT_SETUP([Python audio track validation])
AT_KEYWORDS([python module_process audio])

AT_SKIP_IF([test "x$TEST_PYTHON_ENABLED" != xyes])

AT_CHECK([[test_pythonpath=${TEST_PYTHONPATH-"$abs_top_srcdir/src/modules"}
PYTHONDONTWRITEBYTECODE=1 \
PYTHONNOUSERSITE=1 \
PYTHONPATH="$test_pythonpath" \
"$PYTHON" - <<'PY'
from speechd_python_modules import speechd_types
from speechd_python_modules.module_process import (
    module_tts_output_send_server,
    module_tts_output_server,
)


def track(bits=16, num_channels=1, num_samples=1, samples=b"\0\0"):
    return speechd_types.AudioTrack(
        bits=bits,
        num_channels=num_channels,
        sample_rate=24000,
        num_samples=num_samples,
        samples=samples,
    )


def check_raises(func, audio_track, expected, audio_format=speechd_types.SPD_AUDIO_LE):
    try:
        func(audio_track, audio_format)
    except ValueError as exc:
        if str(exc) != expected:
            raise SystemExit("unexpected error %r, expected %r" % (str(exc), expected))
    else:
        raise SystemExit("expected ValueError: %s" % expected)


check_raises(
    module_tts_output_server,
    track(bits=7),
    "track.bits must be a positive multiple of 8",
)
check_raises(
    module_tts_output_server,
    track(bits=0),
    "track.bits must be a positive multiple of 8",
)
check_raises(
    module_tts_output_server,
    track(num_channels=0),
    "track.num_channels must be positive",
)
check_raises(
    module_tts_output_server,
    track(num_samples=-1, samples=b""),
    "track.num_samples must not be negative",
)
check_raises(
    module_tts_output_server,
    track(bits=80008, samples=b""),
    "sample size is larger than MAX_CHUNK",
)
check_raises(
    module_tts_output_send_server,
    track(num_samples=2, samples=b"\0\0"),
    "invalid AudioTrack payload size: got 2 bytes, expected 4",
)
check_raises(
    module_tts_output_server,
    track(num_samples=2, samples=b"\0\0\0\0\0"),
    "invalid AudioTrack payload size: got 5 bytes, expected 4",
)
check_raises(
    module_tts_output_send_server,
    track(),
    "invalid audio format",
    audio_format=99,
)
PY
