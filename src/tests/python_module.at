AT_SETUP([Python audio track chunking])
AT_KEYWORDS([python module_process audio])

AT_SKIP_IF([test "x$TEST_PYTHON_ENABLED" != xyes])

AT_CHECK([[test_pythonpath=${TEST_PYTHONPATH-"$abs_top_srcdir/src/modules"}
PYTHONDONTWRITEBYTECODE=1 \
PYTHONNOUSERSITE=1 \
PYTHONPATH="$test_pythonpath" \
"$PYTHON" - <<'PY'
import sys

from speechd_python_modules import speechd_types
from speechd_python_modules.module_process import module_tts_output_server


class FakeStdout:
    def __init__(self):
        self.chunks = []
        self.buffer = self

    def write(self, data):
        if isinstance(data, str):
            data = data.encode("utf-8")
        self.chunks.append(data)
        return len(data)

    def flush(self):
        pass

    def value(self):
        return b"".join(self.chunks)


samples = b"\x01\x00" * 6001
track = speechd_types.AudioTrack(
    bits=16,
    num_channels=1,
    sample_rate=24000,
    num_samples=6001,
    samples=samples,
)

stdout = FakeStdout()
old_stdout = sys.stdout
try:
    sys.stdout = stdout
    module_tts_output_server(track, speechd_types.SPD_AUDIO_LE)
finally:
    sys.stdout = old_stdout

output = stdout.value()
if len(stdout.chunks) != 2:
    raise SystemExit("expected one write per audio chunk, got %d" % len(stdout.chunks))
if output.count(b"705-AUDIO\0") != 2:
    raise SystemExit("unexpected number of audio chunks: %r" % output)
if output.count(b"\n705 AUDIO\n") != 2:
    raise SystemExit("unexpected number of audio footers: %r" % output)
if b"705-num_samples=5000\n" not in output:
    raise SystemExit("first chunk size missing: %r" % output)
if b"705-num_samples=1001\n" not in output:
    raise SystemExit("second chunk size missing: %r" % output)

first = output.find(b"705-num_samples=5000\n")
second = output.find(b"705-num_samples=1001\n")
if first == -1 or second == -1 or first > second:
    raise SystemExit("audio chunks are not in the expected order: %r" % output)
PY
